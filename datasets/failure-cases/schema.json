{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentproof.dev/schemas/failure-case/1.0.0/schema.json",
  "title": "AgentProof Failure Case",
  "description": "M0-01 frozen, provenance-aware failure-case record. Schema version 1.0.0.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "title",
    "normalized_title",
    "primary_category",
    "secondary_categories",
    "description",
    "root_cause",
    "trigger_condition",
    "primary_source",
    "additional_sources",
    "affected_stack",
    "reproduction_status",
    "reproduction",
    "expected_detection_methods",
    "expected_evidence",
    "severity",
    "privacy_redaction",
    "deduplication",
    "review_status",
    "review",
    "is_example",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0",
      "description": "Required for future migrations; breaking changes increment the major version."
    },
    "id": {
      "type": "string",
      "pattern": "^fc-[0-9]{4}-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 160
    },
    "normalized_title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 160,
      "description": "Lower-noise title used for human-assisted deduplication."
    },
    "primary_category": {
      "$ref": "#/$defs/category"
    },
    "secondary_categories": {
      "type": "array",
      "maxItems": 5,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/category"
      }
    },
    "description": {
      "type": "string",
      "minLength": 20,
      "maxLength": 4000
    },
    "root_cause": {
      "type": "string",
      "minLength": 5,
      "maxLength": 1000
    },
    "trigger_condition": {
      "type": "string",
      "minLength": 5,
      "maxLength": 1000
    },
    "primary_source": {
      "$ref": "#/$defs/sourceRecord"
    },
    "additional_sources": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "$ref": "#/$defs/sourceRecord"
      }
    },
    "affected_stack": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      }
    },
    "reproduction_status": {
      "type": "string",
      "enum": [
        "not_attempted",
        "steps_available",
        "reproduced",
        "partially_reproduced",
        "failed_to_reproduce",
        "environment_unavailable",
        "not_applicable"
      ]
    },
    "reproduction": {
      "$ref": "#/$defs/reproductionRecord"
    },
    "expected_detection_methods": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "$ref": "#/$defs/detectionMethod"
      }
    },
    "expected_evidence": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "git_diff",
          "build_log",
          "test_output",
          "exit_code",
          "api_request",
          "api_response",
          "database_query",
          "database_snapshot",
          "browser_screenshot",
          "playwright_trace",
          "console_log",
          "network_log",
          "dom_assertion",
          "file_hash",
          "configuration_diff",
          "repeated_run_comparison",
          "manual_observation"
        ]
      }
    },
    "severity": {
      "type": "string",
      "enum": ["informational", "low", "medium", "high", "blocking"]
    },
    "privacy_redaction": {
      "$ref": "#/$defs/privacyRedaction"
    },
    "deduplication": {
      "$ref": "#/$defs/deduplication"
    },
    "review_status": {
      "type": "string",
      "enum": ["draft", "rejected", "approved"]
    },
    "review": {
      "$ref": "#/$defs/reviewRecord"
    },
    "is_example": {
      "type": "boolean"
    },
    "notes": {
      "type": "string",
      "maxLength": 4000
    }
  },
  "$defs": {
    "category": {
      "type": "string",
      "enum": [
        "missing_implementation",
        "superficial_completion",
        "weakened_tests",
        "authorization_bypass",
        "hardcoded_behavior",
        "non_persistent_state",
        "ui_api_inconsistency",
        "build_runtime_mismatch",
        "incomplete_edge_cases",
        "false_completion_claim",
        "data_integrity_failure",
        "security_regression",
        "nondeterministic_result",
        "environment_dependency",
        "needs_review"
      ]
    },
    "approvedCategory": {
      "type": "string",
      "enum": [
        "missing_implementation",
        "superficial_completion",
        "weakened_tests",
        "authorization_bypass",
        "hardcoded_behavior",
        "non_persistent_state",
        "ui_api_inconsistency",
        "build_runtime_mismatch",
        "incomplete_edge_cases",
        "false_completion_claim",
        "data_integrity_failure",
        "security_regression",
        "nondeterministic_result",
        "environment_dependency"
      ]
    },
    "sourceType": {
      "type": "string",
      "enum": [
        "public_github_issue",
        "public_bug_report",
        "public_article_or_postmortem",
        "public_forum_or_discussion",
        "project_owned_record",
        "authorized_private_report",
        "personal_experience",
        "synthetic_demo",
        "model_generated_candidate"
      ]
    },
    "sourceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "source_title",
        "source_reference",
        "source_date",
        "source_verification_status",
        "verified",
        "verified_at",
        "verification_method",
        "verification_actor_type",
        "verified_by_role",
        "permission_or_authorization",
        "can_publish",
        "redaction_notes"
      ],
      "properties": {
        "source_type": {
          "$ref": "#/$defs/sourceType"
        },
        "source_title": {
          "type": "string",
          "minLength": 3,
          "maxLength": 300
        },
        "source_reference": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 1000
        },
        "source_date": {
          "type": ["string", "null"],
          "format": "date"
        },
        "source_verification_status": {
          "type": "string",
          "enum": ["source_pending", "source_verified"]
        },
        "verified": {
          "type": "boolean"
        },
        "verified_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "verification_method": {
          "type": ["string", "null"],
          "minLength": 3,
          "maxLength": 1000
        },
        "verification_actor_type": {
          "type": "string",
          "enum": ["human", "not_applicable"]
        },
        "verified_by_role": {
          "type": ["string", "null"],
          "minLength": 2,
          "maxLength": 100
        },
        "permission_or_authorization": {
          "type": "string",
          "minLength": 3,
          "maxLength": 1000
        },
        "can_publish": {
          "type": "boolean"
        },
        "redaction_notes": {
          "type": "string",
          "minLength": 3,
          "maxLength": 1000
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "source_verification_status": {"const": "source_verified"}
            },
            "required": ["source_verification_status"]
          },
          "then": {
            "properties": {
              "verified": {"const": true},
              "source_reference": {"type": "string", "minLength": 1},
              "verified_at": {"type": "string", "format": "date-time"},
              "verification_method": {"type": "string", "minLength": 3},
              "verification_actor_type": {"const": "human"},
              "verified_by_role": {"type": "string", "minLength": 2}
            }
          }
        },
        {
          "if": {
            "properties": {
              "source_verification_status": {"const": "source_pending"}
            },
            "required": ["source_verification_status"]
          },
          "then": {
            "properties": {
              "verified": {"const": false}
            }
          }
        },
        {
          "if": {
            "properties": {
              "source_type": {"const": "model_generated_candidate"}
            },
            "required": ["source_type"]
          },
          "then": {
            "properties": {
              "source_verification_status": {"const": "source_pending"},
              "verified": {"const": false}
            }
          }
        }
      ]
    },
    "reproductionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prerequisites",
        "repository_or_demo_version",
        "commit",
        "environment",
        "install_command",
        "start_command",
        "steps",
        "expected_behavior",
        "actual_behavior",
        "attempts",
        "successful_reproductions",
        "random_seed",
        "raw_output_location",
        "known_limitations"
      ],
      "properties": {
        "prerequisites": {
          "type": "array",
          "maxItems": 50,
          "items": {"type": "string", "minLength": 1, "maxLength": 500}
        },
        "repository_or_demo_version": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 200
        },
        "commit": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-fA-F]{7,64}$"
        },
        "environment": {
          "type": "string",
          "minLength": 3,
          "maxLength": 2000
        },
        "install_command": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 1000
        },
        "start_command": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 1000
        },
        "steps": {
          "type": "array",
          "maxItems": 100,
          "items": {"type": "string", "minLength": 1, "maxLength": 1000}
        },
        "expected_behavior": {
          "type": "string",
          "minLength": 10,
          "maxLength": 4000
        },
        "actual_behavior": {
          "type": "string",
          "minLength": 10,
          "maxLength": 4000
        },
        "attempts": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "successful_reproductions": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "random_seed": {
          "type": ["string", "null"],
          "maxLength": 200
        },
        "raw_output_location": {
          "type": ["string", "null"],
          "minLength": 1,
          "maxLength": 500
        },
        "known_limitations": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "detectionMethod": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "description", "proves", "does_not_prove", "deterministic"],
      "properties": {
        "method": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{2,63}$"
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1000
        },
        "proves": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1000
        },
        "does_not_prove": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1000
        },
        "deterministic": {
          "type": "boolean"
        }
      }
    },
    "privacyRedaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "redacted_items",
        "method",
        "performed_by_role",
        "performed_at",
        "review_status",
        "reviewed_by_role",
        "reviewed_at",
        "notes"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "not_required", "completed"]
        },
        "redacted_items": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 200}
        },
        "method": {
          "type": "string",
          "minLength": 3,
          "maxLength": 1000
        },
        "performed_by_role": {
          "type": ["string", "null"],
          "minLength": 2,
          "maxLength": 100
        },
        "performed_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "review_status": {
          "type": "string",
          "enum": ["pending", "reviewed"]
        },
        "reviewed_by_role": {
          "type": ["string", "null"],
          "minLength": 2,
          "maxLength": 100
        },
        "reviewed_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "notes": {
          "type": "string",
          "maxLength": 1000
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"status": {"const": "completed"}},
            "required": ["status"]
          },
          "then": {
            "properties": {
              "redacted_items": {"minItems": 1},
              "performed_by_role": {"type": "string", "minLength": 2},
              "performed_at": {"type": "string", "format": "date-time"}
            }
          }
        },
        {
          "if": {
            "properties": {"review_status": {"const": "reviewed"}},
            "required": ["review_status"]
          },
          "then": {
            "properties": {
              "reviewed_by_role": {"type": "string", "minLength": 2},
              "reviewed_at": {"type": "string", "format": "date-time"}
            }
          }
        }
      ]
    },
    "deduplication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "duplicate_of",
        "related_cases",
        "review_notes",
        "confirmed_by_role",
        "confirmed_at"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_checked", "candidate", "unique", "duplicate", "merged"]
        },
        "duplicate_of": {
          "type": ["string", "null"],
          "pattern": "^fc-[0-9]{4}-[0-9]{4}$"
        },
        "related_cases": {
          "type": "array",
          "uniqueItems": true,
          "maxItems": 50,
          "items": {"type": "string", "pattern": "^fc-[0-9]{4}-[0-9]{4}$"}
        },
        "review_notes": {
          "type": "string",
          "minLength": 3,
          "maxLength": 2000
        },
        "confirmed_by_role": {
          "type": ["string", "null"],
          "minLength": 2,
          "maxLength": 100
        },
        "confirmed_at": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"status": {"const": "duplicate"}},
            "required": ["status"]
          },
          "then": {
            "properties": {
              "duplicate_of": {"type": "string", "pattern": "^fc-[0-9]{4}-[0-9]{4}$"},
              "confirmed_by_role": {"type": "string", "minLength": 2},
              "confirmed_at": {"type": "string", "format": "date-time"}
            }
          }
        },
        {
          "if": {
            "properties": {"status": {"enum": ["unique", "merged"]}},
            "required": ["status"]
          },
          "then": {
            "properties": {
              "duplicate_of": {"type": "null"},
              "confirmed_by_role": {"type": "string", "minLength": 2},
              "confirmed_at": {"type": "string", "format": "date-time"}
            }
          }
        },
        {
          "if": {
            "properties": {"status": {"const": "merged"}},
            "required": ["status"]
          },
          "then": {
            "properties": {
              "duplicate_of": {"type": "null"},
              "related_cases": {"minItems": 1},
              "confirmed_by_role": {"type": "string", "minLength": 2},
              "confirmed_at": {"type": "string", "format": "date-time"}
            }
          }
        }
      ]
    },
    "reviewRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewer_type",
        "reviewer_role",
        "reviewed_at",
        "checklist_version",
        "decision_notes",
        "rejection_reason"
      ],
      "properties": {
        "reviewer_type": {
          "enum": ["human", null]
        },
        "reviewer_role": {
          "type": ["string", "null"],
          "minLength": 2,
          "maxLength": 100
        },
        "reviewed_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "checklist_version": {
          "const": "1.0.0"
        },
        "decision_notes": {
          "type": "string",
          "maxLength": 2000
        },
        "rejection_reason": {
          "type": ["string", "null"],
          "minLength": 5,
          "maxLength": 1000
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"review_status": {"const": "approved"}},
        "required": ["review_status"]
      },
      "then": {
        "properties": {
          "is_example": {"const": false},
          "primary_category": {"$ref": "#/$defs/approvedCategory"},
          "secondary_categories": {
            "items": {"$ref": "#/$defs/approvedCategory"}
          },
          "primary_source": {
            "properties": {
              "source_type": {
                "not": {
                  "enum": ["synthetic_demo", "model_generated_candidate"]
                }
              },
              "source_verification_status": {"const": "source_verified"},
              "verified": {"const": true}
            }
          },
          "privacy_redaction": {
            "properties": {
              "status": {"enum": ["not_required", "completed"]},
              "review_status": {"const": "reviewed"}
            }
          },
          "deduplication": {
            "properties": {
              "status": {"enum": ["unique", "merged"]},
              "confirmed_by_role": {"type": "string", "minLength": 2},
              "confirmed_at": {"type": "string", "format": "date-time"}
            }
          },
          "review": {
            "properties": {
              "reviewer_type": {"const": "human"},
              "reviewer_role": {"type": "string", "minLength": 2},
              "reviewed_at": {"type": "string", "format": "date-time"},
              "decision_notes": {"type": "string", "minLength": 10},
              "rejection_reason": {"type": "null"}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"review_status": {"const": "rejected"}},
        "required": ["review_status"]
      },
      "then": {
        "properties": {
          "review": {
            "properties": {
              "reviewer_type": {"const": "human"},
              "reviewer_role": {"type": "string", "minLength": 2},
              "reviewed_at": {"type": "string", "format": "date-time"},
              "decision_notes": {"type": "string", "minLength": 10},
              "rejection_reason": {"type": "string", "minLength": 5}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "deduplication": {
            "properties": {"status": {"const": "duplicate"}},
            "required": ["status"]
          }
        },
        "required": ["deduplication"]
      },
      "then": {
        "properties": {
          "review_status": {"const": "rejected"}
        }
      }
    },
    {
      "if": {
        "properties": {
          "primary_source": {
            "properties": {
              "source_type": {"const": "model_generated_candidate"}
            },
            "required": ["source_type"]
          }
        },
        "required": ["primary_source"]
      },
      "then": {
        "properties": {
          "review_status": {"enum": ["draft", "rejected"]},
          "is_example": {"const": true}
        }
      }
    },
    {
      "if": {
        "properties": {
          "primary_source": {
            "properties": {
              "source_type": {"const": "synthetic_demo"}
            },
            "required": ["source_type"]
          }
        },
        "required": ["primary_source"]
      },
      "then": {
        "properties": {
          "is_example": {"const": true},
          "review_status": {"enum": ["draft", "rejected"]}
        }
      }
    },
    {
      "if": {
        "properties": {"reproduction_status": {"const": "not_attempted"}},
        "required": ["reproduction_status"]
      },
      "then": {
        "properties": {
          "reproduction": {
            "properties": {
              "attempts": {"const": 0},
              "successful_reproductions": {"const": 0}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"reproduction_status": {"const": "steps_available"}},
        "required": ["reproduction_status"]
      },
      "then": {
        "properties": {
          "reproduction": {
            "properties": {
              "steps": {"minItems": 1},
              "attempts": {"const": 0},
              "successful_reproductions": {"const": 0}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"reproduction_status": {"const": "reproduced"}},
        "required": ["reproduction_status"]
      },
      "then": {
        "properties": {
          "reproduction": {
            "properties": {
              "steps": {"minItems": 1},
              "attempts": {"minimum": 1},
              "successful_reproductions": {"minimum": 1}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"reproduction_status": {"const": "partially_reproduced"}},
        "required": ["reproduction_status"]
      },
      "then": {
        "properties": {
          "reproduction": {
            "properties": {
              "steps": {"minItems": 1},
              "attempts": {"minimum": 1}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"reproduction_status": {"const": "failed_to_reproduce"}},
        "required": ["reproduction_status"]
      },
      "then": {
        "properties": {
          "reproduction": {
            "properties": {
              "steps": {"minItems": 1},
              "attempts": {"minimum": 1},
              "successful_reproductions": {"const": 0}
            }
          }
        }
      }
    }
  ]
}
