{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vericrate.dev/schemas/failure-case-review/1.0.0/review-summary-schema.json",
  "title": "VeriCrate M0 Candidate Review Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_schema_version",
    "generated_on",
    "status",
    "candidate_total",
    "source_accessible_count",
    "source_fully_matched_by_codex_count",
    "source_partially_matched_by_codex_count",
    "human_source_verified_count",
    "source_check_results",
    "group_counts",
    "duplicate_candidate_count",
    "merge_suggestion_count",
    "privacy_or_license_risk_count",
    "redaction_change_count",
    "candidate_correction_count",
    "candidate_field_correction_count",
    "by_agent_or_tool",
    "by_suggested_primary_category",
    "reproduction_information_quality",
    "suggested_manual_review_ids",
    "needs_more_evidence_ids",
    "suggested_reject_or_merge_ids",
    "missing_categories",
    "missing_source_types",
    "scope_audit",
    "manual_confirmation_required",
    "notes"
  ],
  "properties": {
    "review_schema_version": {
      "const": "1.0.0"
    },
    "generated_on": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "const": "codex_review_pending_manual_confirmation"
    },
    "candidate_total": {
      "type": "integer",
      "minimum": 0
    },
    "source_accessible_count": {
      "type": "integer",
      "minimum": 0
    },
    "source_fully_matched_by_codex_count": {
      "type": "integer",
      "minimum": 0
    },
    "source_partially_matched_by_codex_count": {
      "type": "integer",
      "minimum": 0
    },
    "human_source_verified_count": {
      "const": 0
    },
    "source_check_results": {
      "$ref": "#/$defs/countMap"
    },
    "group_counts": {
      "$ref": "#/$defs/countMap"
    },
    "duplicate_candidate_count": {
      "type": "integer",
      "minimum": 0
    },
    "merge_suggestion_count": {
      "type": "integer",
      "minimum": 0
    },
    "privacy_or_license_risk_count": {
      "type": "integer",
      "minimum": 0
    },
    "redaction_change_count": {
      "type": "integer",
      "minimum": 0
    },
    "candidate_correction_count": {
      "type": "integer",
      "minimum": 0
    },
    "candidate_field_correction_count": {
      "type": "integer",
      "minimum": 0
    },
    "by_agent_or_tool": {
      "$ref": "#/$defs/countMap"
    },
    "by_suggested_primary_category": {
      "$ref": "#/$defs/countMap"
    },
    "reproduction_information_quality": {
      "$ref": "#/$defs/countMap"
    },
    "suggested_manual_review_ids": {
      "$ref": "#/$defs/idList"
    },
    "needs_more_evidence_ids": {
      "$ref": "#/$defs/idList"
    },
    "suggested_reject_or_merge_ids": {
      "$ref": "#/$defs/idList"
    },
    "missing_categories": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "missing_source_types": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "manual_confirmation_required": {
      "const": true
    },
    "notes": {
      "type": "string",
      "minLength": 20,
      "maxLength": 2000
    },
    "scope_audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generated_on",
        "status",
        "candidate_total",
        "core_in_scope_count",
        "secondary_research_count",
        "out_of_scope_count",
        "mvp_detectable_yes_count",
        "mvp_detectable_partial_count",
        "mvp_detectable_no_count",
        "core_category_distribution",
        "missing_categories",
        "category_gap_analysis",
        "recommended_keep_for_final_review_ids",
        "recommended_secondary_research_ids",
        "recommended_reject_scope_ids",
        "meets_20_final_candidate_target",
        "shortfall_to_20",
        "manual_confirmation_required",
        "notes"
      ],
      "properties": {
        "generated_on": {
          "type": "string",
          "format": "date"
        },
        "status": {
          "const": "codex_scope_audit_pending_manual_confirmation"
        },
        "candidate_total": {
          "type": "integer",
          "minimum": 0
        },
        "core_in_scope_count": {
          "type": "integer",
          "minimum": 0
        },
        "secondary_research_count": {
          "type": "integer",
          "minimum": 0
        },
        "out_of_scope_count": {
          "type": "integer",
          "minimum": 0
        },
        "mvp_detectable_yes_count": {
          "type": "integer",
          "minimum": 0
        },
        "mvp_detectable_partial_count": {
          "type": "integer",
          "minimum": 0
        },
        "mvp_detectable_no_count": {
          "type": "integer",
          "minimum": 0
        },
        "core_category_distribution": {
          "$ref": "#/$defs/countMap"
        },
        "missing_categories": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 3
          }
        },
        "category_gap_analysis": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "category",
              "current_candidate_status",
              "recommendation"
            ],
            "properties": {
              "category": {
                "type": "string",
                "minLength": 3
              },
              "current_candidate_status": {
                "type": "string",
                "minLength": 20,
                "maxLength": 1000
              },
              "recommendation": {
                "type": "string",
                "minLength": 20,
                "maxLength": 1000
              }
            }
          }
        },
        "recommended_keep_for_final_review_ids": {
          "$ref": "#/$defs/idList"
        },
        "recommended_secondary_research_ids": {
          "$ref": "#/$defs/idList"
        },
        "recommended_reject_scope_ids": {
          "$ref": "#/$defs/idList"
        },
        "meets_20_final_candidate_target": {
          "type": "boolean"
        },
        "shortfall_to_20": {
          "type": "integer",
          "minimum": 0
        },
        "manual_confirmation_required": {
          "const": true
        },
        "notes": {
          "type": "string",
          "minLength": 20,
          "maxLength": 2000
        }
      }
    }
  },
  "$defs": {
    "countMap": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "idList": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^candidate-[0-9]{4}$"
      }
    }
  }
}
