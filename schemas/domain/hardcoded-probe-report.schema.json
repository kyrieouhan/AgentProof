{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0-m3"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "control_run": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "expected_status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        }
      },
      "required": [
        "label",
        "status",
        "expected_status"
      ],
      "additionalProperties": false
    },
    "randomized_runs": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "integer",
            "minimum": 100,
            "maximum": 599
          },
          "expected_status": {
            "type": "integer",
            "minimum": 100,
            "maximum": 599
          }
        },
        "required": [
          "label",
          "status",
          "expected_status"
        ],
        "additionalProperties": false
      }
    },
    "risk_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recommendation": {
      "type": "string",
      "enum": [
        "no_hardcoded_behavior_detected",
        "human_review"
      ]
    }
  },
  "required": [
    "schema_version",
    "source",
    "control_run",
    "randomized_runs",
    "risk_count",
    "risks",
    "recommendation"
  ],
  "additionalProperties": false
}
