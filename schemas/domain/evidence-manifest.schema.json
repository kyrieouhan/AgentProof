{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0-m3"
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "commit": {
      "type": "string",
      "minLength": 1
    },
    "runner_profile": {
      "type": "string",
      "minLength": 1
    },
    "image_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "seed": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "evidence_id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": [
              "request",
              "response",
              "database_snapshot",
              "command_log",
              "manifest",
              "redacted_report",
              "screenshot",
              "browser_event_log",
              "browser_trace",
              "joined_observation"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        },
        "required": [
          "evidence_id",
          "type",
          "path",
          "sha256"
        ],
        "additionalProperties": false
      }
    },
    "redaction": {
      "type": "object",
      "properties": {
        "redacted_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "redacted_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": [
        "redacted_count",
        "redacted_paths"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "schema_version",
    "manifest_id",
    "run_id",
    "commit",
    "runner_profile",
    "image_digest",
    "seed",
    "generated_at",
    "evidence",
    "redaction"
  ],
  "additionalProperties": false
}
