{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0-m3"
    },
    "flow_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "timeout_ms": {
      "default": 5000,
      "type": "integer",
      "exclusiveMinimum": 0,
      "maximum": 9007199254740991
    },
    "steps": {
      "minItems": 1,
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "action": {
                "type": "string",
                "const": "goto"
              },
              "path": {
                "type": "string",
                "pattern": "^\\/.*"
              }
            },
            "required": [
              "action",
              "path"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "action": {
                "type": "string",
                "const": "fill"
              },
              "target": {
                "oneOf": [
                  {
                    "type": "object",
                    "properties": {
                      "strategy": {
                        "type": "string",
                        "const": "css"
                      },
                      "selector": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "strategy",
                      "selector"
                    ],
                    "additionalProperties": false
                  },
                  {
                    "type": "object",
                    "properties": {
                      "strategy": {
                        "type": "string",
                        "const": "role"
                      },
                      "role": {
                        "type": "string",
                        "minLength": 1
                      },
                      "name": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "strategy",
                      "role",
                      "name"
                    ],
                    "additionalProperties": false
                  }
                ]
              },
              "value": {
                "type": "string"
              }
            },
            "required": [
              "action",
              "target",
              "value"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "action": {
                "type": "string",
                "const": "click"
              },
              "target": {
                "oneOf": [
                  {
                    "type": "object",
                    "properties": {
                      "strategy": {
                        "type": "string",
                        "const": "css"
                      },
                      "selector": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "strategy",
                      "selector"
                    ],
                    "additionalProperties": false
                  },
                  {
                    "type": "object",
                    "properties": {
                      "strategy": {
                        "type": "string",
                        "const": "role"
                      },
                      "role": {
                        "type": "string",
                        "minLength": 1
                      },
                      "name": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "strategy",
                      "role",
                      "name"
                    ],
                    "additionalProperties": false
                  }
                ]
              }
            },
            "required": [
              "action",
              "target"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "action": {
                "type": "string",
                "const": "expect_text"
              },
              "target": {
                "oneOf": [
                  {
                    "type": "object",
                    "properties": {
                      "strategy": {
                        "type": "string",
                        "const": "css"
                      },
                      "selector": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "strategy",
                      "selector"
                    ],
                    "additionalProperties": false
                  },
                  {
                    "type": "object",
                    "properties": {
                      "strategy": {
                        "type": "string",
                        "const": "role"
                      },
                      "role": {
                        "type": "string",
                        "minLength": 1
                      },
                      "name": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "strategy",
                      "role",
                      "name"
                    ],
                    "additionalProperties": false
                  }
                ]
              },
              "text": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "action",
              "target",
              "text"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "action": {
                "type": "string",
                "const": "expect_url"
              },
              "path": {
                "type": "string",
                "pattern": "^\\/.*"
              }
            },
            "required": [
              "action",
              "path"
            ],
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "required": [
    "schema_version",
    "flow_id",
    "title",
    "timeout_ms",
    "steps"
  ],
  "additionalProperties": false
}
