{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0-m3"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "commit": {
      "type": "string",
      "minLength": 1
    },
    "runner_profile": {
      "type": "string",
      "minLength": 1
    },
    "image_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "seed": {
      "type": "string",
      "minLength": 1
    },
    "criteria": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "1.0.0-m3"
          },
          "criterion_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "informational",
              "low",
              "medium",
              "high",
              "blocking"
            ]
          },
          "assertions": {
            "minItems": 1,
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "properties": {
                    "kind": {
                      "type": "string",
                      "const": "api"
                    },
                    "method": {
                      "type": "string",
                      "enum": [
                        "GET",
                        "POST",
                        "PUT",
                        "PATCH",
                        "DELETE"
                      ]
                    },
                    "path": {
                      "type": "string",
                      "pattern": "^\\/.*"
                    },
                    "expected_status": {
                      "type": "integer",
                      "minimum": 100,
                      "maximum": 599
                    },
                    "expected_headers": {
                      "type": "object",
                      "propertyNames": {
                        "type": "string"
                      },
                      "additionalProperties": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "expected_json": {
                      "type": "object",
                      "propertyNames": {
                        "type": "string"
                      },
                      "additionalProperties": {}
                    },
                    "max_duration_ms": {
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    }
                  },
                  "required": [
                    "kind",
                    "method",
                    "path",
                    "expected_status"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "kind": {
                      "type": "string",
                      "const": "database"
                    },
                    "check_id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "description": {
                      "type": "string",
                      "minLength": 1
                    },
                    "expected": {
                      "type": "object",
                      "propertyNames": {
                        "type": "string"
                      },
                      "additionalProperties": {}
                    }
                  },
                  "required": [
                    "kind",
                    "check_id",
                    "description",
                    "expected"
                  ],
                  "additionalProperties": false
                }
              ]
            }
          },
          "manual_confirmation_required": {
            "type": "boolean",
            "const": true
          }
        },
        "required": [
          "schema_version",
          "criterion_id",
          "title",
          "description",
          "severity",
          "assertions",
          "manual_confirmation_required"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "commit",
    "runner_profile",
    "image_digest",
    "seed",
    "criteria"
  ],
  "additionalProperties": false
}
