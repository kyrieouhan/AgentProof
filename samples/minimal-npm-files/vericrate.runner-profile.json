{
  "schema_version": "1.0.0-m1",
  "repo_path": "samples/minimal-npm-files",
  "commit": "HEAD",
  "image": "node:20-bookworm",
  "workdir": ".",
  "node_version": "20",
  "package_manager": "npm",
  "commands": {
    "install": "npm ci",
    "build": "npm run build",
    "test": "npm test",
    "start": "npm start"
  },
  "healthcheck": {
    "method": "GET",
    "path": "/health",
    "expected_status": 200,
    "timeout_ms": 1000,
    "retries": 20
  },
  "port": 3103,
  "env_allowlist": [
    {
      "name": "NODE_ENV",
      "source": "runner",
      "value": "test"
    },
    {
      "name": "PORT",
      "source": "runner",
      "value": "3103"
    }
  ],
  "resource_limits": {
    "cpu": "1",
    "memory_mb": 512,
    "pids": 128,
    "disk_mb": 512,
    "file_count": 5000,
    "stdout_stderr_mb": 5,
    "command_timeout_ms": 120000,
    "service_start_timeout_ms": 30000
  },
  "network_policy": {
    "default": "deny",
    "install_phase": "restricted_dependency_sources"
  },
  "mount_policy": {
    "docker_socket": "forbidden",
    "host_home": "forbidden",
    "ssh_keys": "forbidden",
    "real_env_files": "forbidden",
    "rules": "read_only",
    "workspace": "temporary_copy"
  },
  "evidence_policy": {
    "capture_stdout_stderr": true,
    "hash_outputs": true,
    "redact_secrets": true,
    "treat_target_outputs_as_untrusted": true
  }
}
